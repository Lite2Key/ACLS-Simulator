{
  "metadata": {
    "id": "unstable-bradycardia-v1",
    "title": "Unstable Bradycardia: Deliberate Pacing Setup",
    "presentationTitle": "Dizzy, Diaphoretic, and Hypotensive",
    "category": "Bradycardia",
    "estimatedMinutes": 8,
    "learningObjectives": [
      "Separate monitor leads from therapy pads",
      "Obtain vascular access before IV medications",
      "Escalate from atropine to pacing when instability persists",
      "Configure pacing and verify capture intentionally"
    ]
  },
  "defaultMode": "realistic",
  "modes": ["guided", "realistic", "instructor"],
  "timings": {
    "transferToBed": { "guided": 20, "realistic": 30, "instructor": 35 },
