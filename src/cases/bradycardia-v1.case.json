  "gates": [
    {
      "id": "atropine_requires_access",
      "type": "hard",
      "action": "give_atropine",
      "requires": ["hasVascularAccess"],
      "message": "Cannot give IV/IO atropine without vascular access."
    },
    {
      "id": "pacing_requires_pads",
      "type": "hard",
      "action": "start_pacing_mode",
      "requires": ["defibPadsAttached"],
      "message": "Attach defibrillator pads before pacing."
    },
    {
      "id": "rate_requires_pacing_mode",
      "type": "hard",
      "action": "set_pacing_rate_70",
      "requires": ["pacingModeActive"],
      "message": "Start pacing mode before setting a pacing rate."
    },
    {
      "id": "current40_requires_pacing_mode",
      "type": "hard",
      "action": "set_pacing_current_40",
      "requires": ["pacingModeActive"],
      "message": "Start pacing mode before setting pacing current."
    },
    {
      "id": "current70_requires_pacing_mode",
      "type": "hard",
      "action": "set_pacing_current_70",
      "requires": ["pacingModeActive"],
      "message": "Start pacing mode before setting pacing current."
    },
    {
      "id": "capture_requires_setup",
      "type": "hard",
      "action": "confirm_capture",
      "requires": ["pacingModeActive", "pacingRateSet", "pacingCurrentSet"],
      "message": "Configure pacing mode, rate, and current before capture check."
    },
    {
      "id": "sync_for_cardioversion",
      "type": "soft",
      "action": "deliver_cardioversion",
      "requires": ["syncEnabled"],
      "message": "Cardioversion delivered without sync in a pulse rhythm.",
      "penalty": 8,
      "onFailureEffect": "worsen_hemodynamics"
    }
  ],
  "narrativeBeats": [
    {
      "id": "early-pads-reminder",
      "atSeconds": 60,
      "message": "Nurse: Pacing will need pads on the chest first.",
      "priority": "info"
    },
    {
      "id": "access-reminder",
      "atSeconds": 110,
      "message": "Tech: We still need IV or IO before meds.",
      "priority": "info",
      "condition": "ifNoAccess"
    },
    {
      "id": "pacing-escalation",
      "atSeconds": 170,
      "message": "Nurse: BP is dropping. We should escalate to pacing now.",
      "priority": "urgent",
      "condition": "ifNoPacingSetup",
      "requiresAcknowledgement": true
    },
    {
      "id": "capture-escalation",
      "atSeconds": 240,
      "message": "Tech: Electrical spikes are present, but do we have mechanical capture?",
      "priority": "urgent",
      "condition": "ifNoCapture",
      "requiresAcknowledgement": true
    }
  ],
  "outcomes": {
    "deteriorateAfterSeconds": 600,
    "maxPenaltyBeforeDeterioration": 24
  },
  "debriefRules": {
    "criticalActions": [
      "attach_monitor_leads",
      "attach_defib_pads",
      "give_atropine",
      "start_pacing_mode",
      "set_pacing_rate_70",
      "set_pacing_current_70",
      "confirm_capture"
    ],
    "goodDecisionActions": [
      "start_transfer_to_bed",
      "start_ems_handoff",
      "start_oxygen",
      "attach_monitor_leads",
      "attach_defib_pads",
      "establish_iv",
      "give_atropine",
      "start_pacing_mode",
      "set_pacing_rate_70",
      "set_pacing_current_70",
      "confirm_capture"
    ],
    "algorithmDeviationActions": [
      "deliver_cardioversion",
      "set_pacing_current_40"
    ]
  },
  "teachingPoints": [
    "Leads provide rhythm information; pads provide electrical therapy capability.",
    "Symptomatic unstable bradycardia with poor atropine response requires pacing escalation.",
    "Capture requires both electrical setup and pulse confirmation, not just monitor spikes.",
    "Parallel setup tasks reduce delay while preserving realistic workflow."
  ]
}
