    "startOxygen": { "guided": 5, "realistic": 8, "instructor": 10 },
    "establishIV": { "guided": 20, "realistic": 32, "instructor": 40 },
    "establishIO": { "guided": 16, "realistic": 25, "instructor": 30 },
    "placeArterialLine": { "guided": 35, "realistic": 50, "instructor": 60 },
    "attachCapnography": { "guided": 8, "realistic": 12, "instructor": 15 }
  },
