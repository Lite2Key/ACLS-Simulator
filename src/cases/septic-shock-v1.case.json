{
  "metadata": {
    "id": "septic-shock-v1",
    "title": "Septic Shock: Early Resuscitation and Reassessment",
    "presentationTitle": "Fever, Confusion, and Hypotension",
    "category": "Shock",
    "module": "General EM Resuscitation",
    "difficulty": "intermediate",
    "clinicalStem": "A 74-year-old woman arrives from a nursing facility febrile, confused, tachycardic, and hypotensive after two days of cough and poor intake.",
    "estimatedMinutes": 10,
    "learningObjectives": [
      "Recognize septic shock physiology early",
      "Run parallel access, monitoring, cultures, fluids, antibiotics, and vasopressor preparation",
      "Avoid anchoring on fluids alone when hypotension persists",
      "Reassess perfusion and disposition after initial stabilization"
    ]
  },
  "defaultMode": "realistic",
  "modes": ["guided", "realistic", "instructor"],
