      "action": "send_lactate",
      "requires": ["hasVascularAccess"],
      "message": "Cannot send lactate without IV/IO access."
    },
    {
      "id": "cultures_require_access",
      "type": "hard",
      "action": "draw_blood_cultures",
      "requires": ["hasVascularAccess"],
      "message": "Cannot draw cultures without IV/IO access."
    },
    {
      "id": "fluids_require_access",
      "type": "hard",
      "action": "give_fluid_bolus",
      "requires": ["hasVascularAccess"],
      "message": "Cannot start a fluid bolus without IV/IO access."
    },
    {
      "id": "antibiotics_require_access",
      "type": "hard",
      "action": "give_antibiotics",
      "requires": ["hasVascularAccess"],
      "message": "Cannot give antibiotics without IV/IO access."
    },
    {
      "id": "cultures_before_antibiotics",
      "type": "soft",
      "action": "give_antibiotics",
      "requires": ["bloodCulturesDrawn"],
      "message": "Antibiotics started before blood cultures were drawn.",
      "penalty": 3,
      "onFailureEffect": "none"
    },
    {
      "id": "norepinephrine_requires_access",
      "type": "hard",
      "action": "start_norepinephrine",
      "requires": ["hasVascularAccess"],
      "message": "Cannot start norepinephrine without IV/IO access."
    },
    {
      "id": "pressors_after_initial_fluids",
      "type": "soft",
      "action": "start_norepinephrine",
      "requires": ["fluidsStarted"],
      "message": "Vasopressor started before any initial crystalloid resuscitation.",
      "penalty": 4,
      "onFailureEffect": "none"
    }
  ],
  "narrativeBeats": [
    {
      "id": "shock-persistence",
      "atSeconds": 100,
      "message": "RN: Repeat pressure is still in the 70s systolic.",
      "priority": "urgent",
      "condition": "ifNoFluids",
      "requiresAcknowledgement": true
    },
    {
      "id": "antibiotic-clock",
      "atSeconds": 180,
      "message": "Pharmacist: Antibiotics are available when you are ready.",
      "priority": "info",
      "condition": "ifNoAntibiotics"
    },
    {
      "id": "pressor-consideration",
      "atSeconds": 260,
      "message": "RN: Two liters are in and MAP is still marginal.",
      "priority": "urgent",
      "condition": "ifNoVasopressor",
      "requiresAcknowledgement": true
    },
    {
      "id": "reassessment-needed",
      "atSeconds": 360,
      "message": "Team: Initial interventions are done; we need a perfusion reassessment.",
